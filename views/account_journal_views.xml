<odoo>
  <record id="view_account_journal_form_inherit_operating_unit" model="ir.ui.view">
    <field name="name">account.journal.form.inherit.operating.unit</field>
    <field name="model">account.journal</field>
    <field name="inherit_id" ref="account.view_journal_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='company_id']" position="after">
        <field name="operating_unit_id"/>
      </xpath>
    </field>
  </record>
</odoo>
